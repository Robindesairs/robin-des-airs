# Amadeus — Radar haute précision (clés .env)
# Copier en .env et remplir. Ne jamais commiter .env.

# Option 1 : noms utilisés par la mission
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Option 2 : noms utilisés par le SDK Amadeus (prioritaires si présents)
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=

# Host Amadeus : test ou production
# AMADEUS_HOST=test.api.amadeus.com
# AMADEUS_HOST=api.amadeus.com

# URL du radar Aviation Edge (Netlify) pour le monitoring
RADAR_URL=https://robin-des-airs.netlify.app/.netlify/functions/radar

# URL de l’API de certifications (backend local ou déployé) — optionnel pour le radar Netlify
# CERTIFICATION_API_URL=http://localhost:3456/api/certifications

# ─── Bot WhatsApp (Railway) : OCR & extraction e-billet ───────────────────────
# Lecture des IMAGES (carte d'embarquement, passeport, e-billet en photo) — déjà requis en prod.
OPENAI_API_KEY=
# Lecture des PDF d'e-billet (bloc document Claude). SANS cette clé, un PDF n'est PAS lu (les images le restent).
ANTHROPIC_API_KEY=
# Modèle Claude pour l'extraction PDF (défaut : claude-sonnet-4-5). Optionnel.
# ETICKET_MODEL=claude-sonnet-4-5

# ─── Yousign — Signature électronique mandat ──────────────────────────────────
# Clé API à créer sur dashboard.yousign.app/settings/api-keys (onglet Sandbox ou Production)
# Compte Yousign = signatures@robindesairs.eu (catch-all DNS — pas besoin de créer)
YOUSIGN_API_KEY=

# Endpoint API Yousign :
#   Sandbox  → https://api-sandbox.yousign.app/v3   (tests gratuits, PDF marqué "TEST")
#   Production → https://api.yousign.app/v3         (KBIS requis, juridiquement opposable)
# Défaut code = production. Mettre en sandbox pour le démarrage.
YOUSIGN_BASE_URL=https://api-sandbox.yousign.app/v3

# Secret HMAC pour vérifier l'authenticité des webhooks Yousign (à venir avec yousign-webhook.js)
# YOUSIGN_WEBHOOK_SECRET=
