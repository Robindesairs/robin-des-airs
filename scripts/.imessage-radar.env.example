# Copie ce fichier en .imessage-radar.env et renseigne ton numéro/Apple ID.
# (.imessage-radar.env est ignoré par git — il contient ton contact.)

# Destinataire iMessage : ton numéro au format international, ou ton Apple ID e-mail.
ROBIN_IMESSAGE_TO=+33XXXXXXXXX

# Optionnel — valeurs par défaut indiquées :
# ROBIN_RADAR_URL=https://robindesairs.eu/api/radar-today
# ROBIN_MIN_DELAY=180
# ROBIN_TODAY_ONLY=1
